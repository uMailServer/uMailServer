# uMailServer Environment Configuration
# Copy this file to .env and modify as needed

# Server Configuration
UMAIL_HOSTNAME=mail.example.com
UMAIL_DATA_DIR=/data/umailserver

# Database
UMAIL_DB_PATH=/data/umailserver/umailserver.db

# SMTP Settings
UMAIL_SMTP_INBOUND_BIND=0.0.0.0
UMAIL_SMTP_INBOUND_PORT=25
UMAIL_SMTP_OUTBOUND_BIND=0.0.0.0
UMAIL_SMTP_OUTBOUND_PORT=587

# IMAP Settings
UMAIL_IMAP_BIND=0.0.0.0
UMAIL_IMAP_PORT=143
UMAIL_IMAP_TLS_PORT=993

# API Settings
UMAIL_API_BIND=0.0.0.0
UMAIL_API_PORT=8080
UMAIL_API_JWT_SECRET=change-this-to-a-secure-random-string

# Logging
UMAIL_LOG_LEVEL=info
UMAIL_LOG_FORMAT=json

# TLS/SSL
UMAIL_TLS_CERT=/data/umailserver/certs/cert.pem
UMAIL_TLS_KEY=/data/umailserver/certs/key.pem

# DKIM
UMAIL_DKIM_ENABLED=true
UMAIL_DKIM_SELECTOR=default
UMAIL_DKIM_PRIVATE_KEY=/data/umailserver/dkim/private.key

# Security
UMAIL_MAX_MESSAGE_SIZE=50MB
UMAIL_MAX_RECIPIENTS=100
UMAIL_AUTH_REQUIRED=true

# Queue
UMAIL_QUEUE_RETRY_ATTEMPTS=5
UMAIL_QUEUE_RETRY_INTERVAL=5m

# Webhooks
UMAIL_WEBHOOK_SECRET=change-this-to-a-secure-webhook-secret
