# uMailServer Configuration Example
# Full documentation: https://docs.umailserver.com/configuration

# Server settings
server:
  hostname: mail.example.com
  data_dir: /var/lib/umailserver
  max_message_size: 50MB

# TLS Configuration
tls:
  cert_file: ""               # Path to TLS certificate (manual mode)
  key_file: ""                # Path to TLS key (manual mode)
  min_version: "1.2"          # Minimum TLS version: "1.2" or "1.3"
  acme:
    enabled: true
    email: admin@example.com
    directory: https://acme-v02.api.letsencrypt.org/directory
    accept_tos: true

# SMTP Server Configuration
smtp:
  inbound:
    enabled: true
    bind: "0.0.0.0"
    port: 25
    max_connections: 100
    max_recipients: 100
  submission:
    enabled: true
    bind: "0.0.0.0"
    port: 587
    require_auth: true
    require_tls: true
    max_connections: 100
  submission_tls:
    enabled: true
    bind: "0.0.0.0"
    port: 465
    require_auth: true
    max_connections: 100

# IMAP Server Configuration
imap:
  enabled: true
  bind: "0.0.0.0"
  port: 993
  starttls_port: 143
  max_connections: 10000      # Max concurrent connections (0 = unlimited)
  idle_timeout: 30m

# HTTP API and Web UI
http:
  enabled: true
  bind: "0.0.0.0"
  port: 443
  tls: true

# Admin Panel (currently serves same server as http)
admin:
  enabled: true
  bind: "127.0.0.1"
  port: 8443

# Spam Filter
spam:
  enabled: true
  threshold: 5.0
  bayesian:
    enabled: true
    auto_learn: true
  greylisting:
    enabled: true
    delay: 5m
  rbl:
    enabled: true
    servers:
      - zen.spamhaus.org

# Security
security:
  jwt_secret: "change-me-to-a-32-character-secret-minimum"
  max_login_attempts: 5
  lockout_duration: 15m
  spf_cache_ttl: 5m           # TTL for cached SPF lookups (default 5m)
  rate_limit:
    smtp_per_minute: 30       # SMTP auth attempts per minute per IP
    smtp_per_hour: 500        # SMTP connections per hour per IP
    imap_connections: 50      # Max concurrent IMAP connections per IP
    http_requests_per_minute: 120  # API requests per minute per IP

# Queue
queue:
  max_retries: 10
  retry_delay: 5m

# Logging
logging:
  level: info
  format: json
  output: stdout              # stdout, stderr, or file path (e.g., /var/log/umailserver/app.log)
  max_size_mb: 100            # Max log file size before rotation (only for file output)
  max_backups: 10             # Number of old log files to keep
  max_age_days: 30            # Max age of old log files in days

# Metrics (Prometheus-compatible)
metrics:
  enabled: true
  bind: "127.0.0.1"
  port: 8080
  path: /metrics

# Distributed Tracing (OpenTelemetry)
tracing:
  enabled: false               # Enable OpenTelemetry tracing
  service_name: "umailserver"  # Service name shown in traces
  exporter: "noop"            # Exporter: "noop", "stdout", or "otlp"
  otlp_endpoint: "localhost:4317"  # OTLP collector endpoint (for otlp exporter)
  environment: "production"   # Environment tag: "production", "staging", "development"
  sample_rate: 1.0            # Sampling rate 0.0-1.0 (1.0 = trace all requests)
  attributes:                 # Additional resource attributes
    deployment: "primary"
    region: "us-east-1"

# Web Push notifications (VAPID-based, mobile + desktop browsers)
# VAPID keys are auto-generated and stored in `<data_dir>/push/vapid.json` on
# first start. Paste them back here only if you need them to survive a data
# wipe or to share keys across replicas. `subject` identifies the operator to
# push services (must be mailto: or https://).
push:
  enabled: true                 # Master switch for browser push delivery
  subject: "mailto:admin@example.com"
  # vapid_public_key: ""        # Optional override — must be set together with vapid_private_key
  # vapid_private_key: ""       # Plain string in YAML; do not commit real values

# Production alerting (webhook + email notifications for system conditions)
# When enabled, the alert manager sends notifications for queue backlog,
# TLS certificate expiry, and other operational thresholds. At least one of
# webhook_url or smtp_server must be set when enabled is true.
alert:
  enabled: false                  # Master switch for alerting
  # Webhook delivery (e.g., Slack, PagerDuty, custom HTTP endpoint)
  webhook_url: ""                 # https://hooks.slack.com/services/...
  webhook_headers: {}             # Optional headers, e.g., {"Authorization": "Bearer xyz"}
  webhook_template: ""            # Optional Go-template body override
  allow_private_ip: false         # Allow webhook URLs to private/loopback IPs (SSRF risk; testing only)
  # Email delivery
  smtp_server: ""                 # smtp.example.com (required for email delivery)
  smtp_port: 587                  # 25, 465, or 587
  smtp_username: ""
  smtp_password: ""               # Plain string in YAML; do not commit real values
  from_address: ""                # alerts@example.com
  to_addresses: []                # ["oncall@example.com"]
  use_tls: true                   # STARTTLS for SMTP delivery
  # Rate limiting (prevents alert storms)
  min_interval: 5m                # Minimum gap between two alerts of the same name
  max_alerts: 100                 # Maximum alerts per hour across all names
  # Thresholds (0 disables the check)
  disk_threshold: 85.0            # Disk usage % that triggers a warning
  memory_threshold: 90.0          # Memory usage % that triggers a warning
  error_threshold: 5.0            # Error rate % that triggers a warning
  tls_warning_days: 7             # Days before cert expiry to alert
  queue_threshold: 1000           # Pending queue items that trigger a warning

# Domains
domains:
  - name: example.com
    max_accounts: 100
    max_mailbox_size: 5GB
    dkim:
      selector: default

# POP3 Server Configuration
pop3:
  enabled: false
  bind: "0.0.0.0"
  port: 995
  max_connections: 10000      # Max concurrent connections (0 = unlimited)

# MCP Server (Model Context Protocol)
mcp:
  enabled: true
  bind: "127.0.0.1"
  port: 3000
  auth_token: ""              # Set to enable authentication

# CalDAV Server (Calendar synchronization)
caldav:
  enabled: false              # Set to true to enable CalDAV
  bind: "127.0.0.1"
  port: 8081                 # CalDAV HTTP server port

# CardDAV Server (Contacts synchronization)
carddav:
  enabled: false             # Set to true to enable CardDAV
  bind: "127.0.0.1"
  port: 8082                 # CardDAV HTTP server port

# JMAP Server (Modern email API)
jmap:
  enabled: false             # Set to true to enable JMAP
  bind: "127.0.0.1"
  port: 8083                 # JMAP HTTP server port
  cors_origins: []           # Allowed CORS origins (empty = allow all)

# LDAP / Active Directory authentication
ldap:
  enabled: false                          # Set to true to enable LDAP auth
  url: "ldaps://ldap.example.com:636"     # ldap:// or ldaps://
  bind_dn: "cn=service,dc=example,dc=com" # Service account for searches
  bind_password: ""                       # Service account password
  base_dn: "ou=users,dc=example,dc=com"   # User search base
  user_filter: "(uid=%s)"                 # %s is replaced with the username
  email_attribute: "mail"
  name_attribute: "cn"
  group_attribute: "memberOf"
  admin_groups: []                        # Group DNs that grant admin access
  start_tls: false                        # Use StartTLS on port 389
  skip_verify: false                      # Skip TLS verification (dev only)
  timeout: 30s
  max_connections: 10                     # Pooled LDAP connections (default 10)
