# uMailServer Configuration Example
# Full documentation: https://docs.umailserver.com/configuration

# Server settings
server:
  hostname: mail.example.com
  data_dir: /var/lib/umailserver
  max_message_size: 50MB

# TLS Configuration
tls:
  cert_dir: certs
  min_version: "1.2"
  acme:
    enabled: true
    email: admin@example.com
    directory: https://acme-v02.api.letsencrypt.org/directory
    accept_tos: true

# SMTP Server Configuration
smtp:
  inbound:
    enabled: true
    bind: "0.0.0.0"
    port: 25
    max_connections: 100
    max_recipients: 100
  submission:
    enabled: true
    bind: "0.0.0.0"
    port: 587
    require_auth: true
    require_tls: true
    max_connections: 100
  submission_tls:
    enabled: true
    bind: "0.0.0.0"
    port: 465
    require_auth: true
    max_connections: 100

# IMAP Server Configuration
imap:
  enabled: true
  bind: "0.0.0.0"
  port: 993
  tls: true
  max_connections_per_user: 10
  session_timeout: 30

# HTTP API and Web UI
http:
  enabled: true
  bind: "0.0.0.0"
  port: 8443
  tls: true

# Admin Panel
admin:
  enabled: true
  bind: "127.0.0.1"
  port: 8443

# Spam Filter
spam:
  enabled: true
  threshold: 5.0
  bayesian:
    enabled: true
    auto_learn: true
  greylisting:
    enabled: true
    delay: 5m
  rbl:
    enabled: true
    servers:
      - zen.spamhaus.org

# Security
security:
  rate_limit:
    enabled: true
    requests_per_minute: 60
  jwt:
    access_token_ttl: 15m
    refresh_token_ttl: 168h

# Queue
queue:
  max_retries: 10
  retry_delay: 5m

# Logging
log:
  level: info
  format: json

# Metrics
metrics:
  enabled: true
  path: /metrics

# Domains
domains:
  - name: example.com
    max_accounts: 100
    max_mailbox_size: 5GB
    dkim:
      selector: default

# MCP Server
mcp:
  enabled: true
  require_auth: true
