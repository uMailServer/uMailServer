# uMailServer Configuration Example
# Full documentation: https://docs.umailserver.com/configuration

# Server settings
server:
  hostname: mail.example.com
  data_dir: /var/lib/umailserver
  max_message_size: 50MB

# TLS Configuration
tls:
  cert_file: ""               # Path to TLS certificate (manual mode)
  key_file: ""                # Path to TLS key (manual mode)
  min_version: "1.2"          # Minimum TLS version: "1.2" or "1.3"
  acme:
    enabled: true
    email: admin@example.com
    directory: https://acme-v02.api.letsencrypt.org/directory
    accept_tos: true

# SMTP Server Configuration
smtp:
  inbound:
    enabled: true
    bind: "0.0.0.0"
    port: 25
    max_connections: 100
    max_recipients: 100
  submission:
    enabled: true
    bind: "0.0.0.0"
    port: 587
    require_auth: true
    require_tls: true
    max_connections: 100
  submission_tls:
    enabled: true
    bind: "0.0.0.0"
    port: 465
    require_auth: true
    max_connections: 100

# IMAP Server Configuration
imap:
  enabled: true
  bind: "0.0.0.0"
  port: 993
  starttls_port: 143
  max_connections: 10000      # Max concurrent connections (0 = unlimited)
  idle_timeout: 30m

# HTTP API and Web UI
http:
  enabled: true
  bind: "0.0.0.0"
  port: 443
  tls: true

# Admin Panel (currently serves same server as http)
admin:
  enabled: true
  bind: "127.0.0.1"
  port: 8443

# Spam Filter
spam:
  enabled: true
  threshold: 5.0
  bayesian:
    enabled: true
    auto_learn: true
  greylisting:
    enabled: true
    delay: 5m
  rbl:
    enabled: true
    servers:
      - zen.spamhaus.org

# Security
security:
  jwt_secret: "change-me-to-a-32-character-secret-minimum"
  max_login_attempts: 5
  lockout_duration: 15m
  rate_limit:
    smtp_per_minute: 30       # SMTP auth attempts per minute per IP
    smtp_per_hour: 500        # SMTP connections per hour per IP
    imap_connections: 50      # Max concurrent IMAP connections per IP
    http_requests_per_minute: 120  # API requests per minute per IP

# Queue
queue:
  max_retries: 10
  retry_delay: 5m

# Logging
logging:
  level: info
  format: json
  output: stdout              # stdout, stderr, or file path (e.g., /var/log/umailserver/app.log)
  max_size_mb: 100            # Max log file size before rotation (only for file output)
  max_backups: 10             # Number of old log files to keep
  max_age_days: 30            # Max age of old log files in days

# Metrics
metrics:
  enabled: true
  path: /metrics

# Domains
domains:
  - name: example.com
    max_accounts: 100
    max_mailbox_size: 5GB
    dkim:
      selector: default

# POP3 Server Configuration
pop3:
  enabled: false
  bind: "0.0.0.0"
  port: 995
  max_connections: 10000      # Max concurrent connections (0 = unlimited)

# MCP Server (Model Context Protocol)
mcp:
  enabled: true
  bind: "127.0.0.1"
  port: 3000
  auth_token: ""              # Set to enable authentication
