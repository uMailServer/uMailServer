# uMailServer Production Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# SERVER SETTINGS
# =============================================================================

# Server hostname (FQDN)
UMAILSERVER_HOSTNAME=mail.example.com

# Data directory for mail storage
#UMAILSERVER_SERVER_DATA_DIR=/data

# =============================================================================
# SECURITY
# =============================================================================

# JWT Secret - MUST BE SET IN PRODUCTION!
# Generate with: openssl rand -base64 32
UMAILSERVER_JWT_SECRET=

# =============================================================================
# TLS / ACME
# =============================================================================

# Enable automatic TLS via Let's Encrypt
UMAILSERVER_TLS_ACME_ENABLED=true

# Email for Let's Encrypt certificates
UMAILSERVER_TLS_ACME_EMAIL=admin@example.com

# =============================================================================
# LOGGING
# =============================================================================

# Log level: debug, info, warn, error
UMAILSERVER_LOGGING_LEVEL=info

# =============================================================================
# SPAM FILTERING
# =============================================================================

# Spam reject threshold (default: 9.0)
#UMAILSERVER_SPAM_REJECT_THRESHOLD=9.0

# =============================================================================
# MONITORING (Grafana)
# =============================================================================

# Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# =============================================================================
# BACKUP SETTINGS
# =============================================================================

# Backup encryption key (AES-256-GCM)
#BACKUP_ENCRYPTION_KEY=

# Backup schedule (cron format)
#BACKUP_SCHEDULE=0 2 * * *

# Backup destination (local path or S3 bucket)
#BACKUP_DESTINATION=/backups

# =============================================================================
# SMTP RELAY (Optional)
# =============================================================================

# External SMTP relay for outbound mail
#UMAILSERVER_SMTP_RELAY_HOST=
#UMAILSERVER_SMTP_RELAY_PORT=587
#UMAILSERVER_SMTP_RELAY_USERNAME=
#UMAILSERVER_SMTP_RELAY_PASSWORD=
#UMAILSERVER_SMTP_RELAY_FROM=